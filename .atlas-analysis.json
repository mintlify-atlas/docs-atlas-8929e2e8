  "keyFeatures": [
    "YJS CRDT-based workspace system for conflict-free collaboration",
    "SQLite provider for SQL queries via Drizzle ORM",
    "Markdown provider for human-readable file persistence",
    "Real-time multi-device sync with y-websocket protocol",
    "Type-safe actions with Standard Schema validation",
    "Local-first architecture with optional cloud sync",
    "Extensible provider system for custom capabilities",
    "Built-in undo/redo and offline support"
  ],
  "publicApiSurface": [
    "defineWorkspace({ id, tables, kv })",
    "createClient(workspaceId).withDefinition().withExtension()",
    "defineQuery({ input, handler })",
    "defineMutation({ input, handler })",
    "sqliteProvider(context)",
    "markdownProvider(context, config)",
    "createSyncExtension({ url })",
    "tables.get(tableName).upsert(row)",
    "tables.get(tableName).get({ id })",
    "tables.get(tableName).delete({ id })",
    "tables.get(tableName).observe(callback)",
    "Column types: id(), text(), ytext(), integer(), real(), boolean(), date(), select(), tags(), json()",
    "DateTimeString.now(timezone)",
    "client.destroy()"
  ]
